def create_ttt_keyboard(game_id, board, current_turn):
    markup = InlineKeyboardMarkup(row_width=3)
    buttons = []
    for i in range(9):
        if board[i] == '-':
            buttons.append(InlineKeyboardButton("⬜", callback_data=f"ttt_{game_id}_{i}"))
        else:
            buttons.append(InlineKeyboardButton(board[i], callback_data="noop"))
    markup.add(*buttons)
    return markup
